# Porta HTTP/WebSocket do backend
PORT=3001

# PostgreSQL + PostGIS (porta 5544 no host via Docker — ver docker-compose.yml)
DATABASE_URL=postgres://volta:volta@localhost:5544/volta_ao_lago
# Em banco gerenciado (Supabase/Neon), use DATABASE_SSL=true
# DATABASE_SSL=true

# Redis (Pub/Sub + cache GEO). Se ausente/indisponível, o backend roda em modo
# memória (instância única) — útil para desenvolvimento sem Docker.
REDIS_URL=redis://localhost:6380

# Segredo JWT (troque em produção)
JWT_SECRET=dev-secret-volta-ao-lago

# Distância (m) para disparar alerta de aproximação de PC
GEOFENCE_RADIUS_M=350

# Origens permitidas no CORS (separe por vírgula). * = libera tudo (dev).
CORS_ORIGIN=*
